{
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",

		// ES2021 (not a newer default) so the TC39 @callable() decorators used
		// by the Agents SDK (see src/server/agents/list-session.ts) downlevel
		// correctly rather than passing through as native syntax workerd can't
		// parse - this applies to both `wrangler dev`'s and `wrangler deploy`'s
		// esbuild-based bundling, not just type-checking.
		"target": "ES2021",
		"lib": ["ES2021"],

		"module": "ES2022",
		"moduleResolution": "node",
		"resolveJsonModule": true,

		"allowJs": true,
		"checkJs": false,
		"noEmit": true,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,

		"types": ["./worker-configuration.d.ts", "node"]
	},
	"include": ["src/server", "src/shared", "worker-configuration.d.ts"]
}
